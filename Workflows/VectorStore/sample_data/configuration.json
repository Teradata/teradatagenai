{
  "application": {
    "name": "CloudSync Pro",
    "version": "3.2.1",
    "environment": "production",
    "deployment_date": "2024-01-15"
  },
  "database": {
    "host": "db.techvision-prod.com",
    "port": 5432,
    "name": "cloudsync_prod",
    "connection_pool": {
      "min_connections": 10,
      "max_connections": 100,
      "idle_timeout": 30000
    },
    "ssl_enabled": true
  },
  "cloud_providers": [
    {
      "provider": "AWS",
      "regions": ["us-east-1", "us-west-2", "eu-west-1", "ap-southeast-1"],
      "services": {
        "s3": {
          "enabled": true,
          "bucket_encryption": "AES256",
          "versioning": true
        },
        "glacier": {
          "enabled": true,
          "retrieval_tier": "standard"
        }
      }
    },
    {
      "provider": "Azure",
      "regions": ["eastus", "westeurope", "southeastasia"],
      "services": {
        "blob_storage": {
          "enabled": true,
          "tier": "hot",
          "redundancy": "GRS"
        }
      }
    },
    {
      "provider": "GCP",
      "regions": ["us-central1", "europe-west1", "asia-east1"],
      "services": {
        "cloud_storage": {
          "enabled": true,
          "storage_class": "STANDARD",
          "lifecycle_management": true
        }
      }
    }
  ],
  "security": {
    "encryption": {
      "algorithm": "AES-256-GCM",
      "key_rotation_days": 90
    },
    "authentication": {
      "method": "oauth2",
      "token_expiry_minutes": 60,
      "refresh_token_expiry_days": 30,
      "multi_factor_auth": true
    },
    "audit_logging": {
      "enabled": true,
      "retention_days": 365,
      "log_level": "INFO"
    }
  },
  "performance": {
    "sync": {
      "batch_size": 1000,
      "max_parallel_transfers": 10,
      "retry_attempts": 3,
      "timeout_seconds": 300
    },
    "cache": {
      "enabled": true,
      "provider": "redis",
      "ttl_seconds": 3600,
      "max_memory_mb": 2048
    }
  },
  "monitoring": {
    "metrics": {
      "enabled": true,
      "interval_seconds": 60,
      "exporters": ["prometheus", "cloudwatch"]
    },
    "alerts": {
      "email": ["ops@techvision-solutions.com"],
      "slack_webhook": "https://hooks.slack.com/services/EXAMPLE",
      "thresholds": {
        "error_rate_percent": 5,
        "response_time_ms": 1000,
        "cpu_percent": 80,
        "memory_percent": 85
      }
    }
  },
  "features": {
    "real_time_sync": true,
    "conflict_resolution": true,
    "version_control": true,
    "compression": true,
    "deduplication": true,
    "bandwidth_throttling": true
  }
}
